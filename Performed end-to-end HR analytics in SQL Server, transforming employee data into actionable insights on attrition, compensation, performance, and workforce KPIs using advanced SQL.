SELECT [JobSatisfaction],
COUNT() AS TotalEmployees,
SUM(CASE WHEN [Attrition] = 1 THEN 1 ELSE 0 END) AS EmployeesWhoLeft,
ROUND((SUM(CASE WHEN [Attrition] = 1 THEN 1 ELSE 0 END) / COUNT()) * 100, 2) AS AttritionRate,
AVG([Age]) AS AverageAge,
AVG([MonthlyIncome]) AS AverageSalary
FROM [PracticeDB].[dbo].[HR-Employee-Attrition]
GROUP BY [JobSatisfaction]
ORDER BY [JobSatisfaction] ASC

SELECT [PerformanceRating],
COUNT() AS TotalEmployees,
SUM(CASE WHEN [Attrition] = 1 THEN 1 ELSE 0 END) AS EmployeesWhoLeft,
ROUND((SUM(CASE WHEN [Attrition] = 1 THEN 1 ELSE 0 END) / COUNT()) * 100, 2) AS AttritionRate,
AVG([Age]) AS AverageAge,
AVG([MonthlyIncome]) AS AverageSalary
FROM [PracticeDB].[dbo].[HR-Employee-Attrition]
GROUP BY [PerformanceRating]
ORDER BY [PerformanceRating] ASC

Promotion eligibility
SELECT [EmployeeNumber], [JobRole], [YearsAtCompany], [PerformanceRating],
CASE
WHEN [YearsAtCompany] >= 5 AND [PerformanceRating] >= 4 THEN 'Eligible for Promotion'
ELSE 'Not Eligible for Promotion'
END AS PromotionEligibility
FROM [PracticeDB].[dbo].[HR-Employee-Attrition]

Salary band analysis
SELECT [EmployeeNumber], [JobRole], [MonthlyIncome],
CASE
WHEN [MonthlyIncome] < 3000 THEN 'Low'
WHEN [MonthlyIncome] BETWEEN 3000 AND 7000 THEN 'Medium'
ELSE 'High'
END AS SalaryBand
FROM [PracticeDB].[dbo].[HR-Employee-Attrition]

High performer, low salary analysis
SELECT [EmployeeNumber], [JobRole], [MonthlyIncome], [PerformanceRating],
CASE
WHEN [PerformanceRating] >= 4 AND [MonthlyIncome] < (SELECT AVG([MonthlyIncome]) FROM [PracticeDB].[dbo].[HR-Employee-Attrition]) THEN 'High Performer, Low Salary'
ELSE 'Not Applicable'
END AS HighPerformerLowSalary
FROM [PracticeDB].[dbo].[HR-Employee-Attrition]

Gender pay gap
SELECT [Gender], AVG([MonthlyIncome]) AS AverageSalary
FROM [PracticeDB].[dbo].[HR-Employee-Attrition]
GROUP BY [Gender]

